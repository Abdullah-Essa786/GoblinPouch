<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Background color -->
    <solid android:color="#1E2A38"/>

    <!-- Rounded corners -->
    <corners android:radius="8dp"/>

    <!-- Padding inside the shape -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#3A4A5A"/>
</shape>
