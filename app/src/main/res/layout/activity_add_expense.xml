<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Amount -->
    <EditText
        android:id="@+id/etExpenseAmount"
        android:hint="Amount (R)"
        android:inputType="numberDecimal"
        android:textColor="#FFFFFF"
        android:textColorHint="#CCCCCC"
        android:background="@drawable/bg_edit"
        android:padding="12dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Category -->
    <Spinner
        android:id="@+id/spCategory"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/bg_edit"
        android:minHeight="48dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/etExpenseAmount" />

    <!-- Date -->
    <TextView
        android:id="@+id/tvExpenseDate"
        android:text="Select Date"
        android:textColor="#FFFFFF"
        android:background="@drawable/bg_edit"
        android:padding="12dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/spCategory"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Notes -->
    <EditText
        android:id="@+id/etNotes"
        android:hint="Notes"
        android:inputType="textMultiLine"
        android:lines="2"
        android:gravity="top"
        android:textColor="#FFFFFF"
        android:textColorHint="#CCCCCC"
        android:background="@drawable/bg_edit"
        android:padding="12dp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvExpenseDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Upload Photo -->
    <Button
        android:id="@+id/btnAttachPhoto"
        android:text="Upload Receipt Photo"
        android:background="@drawable/bg_edit"
        android:textColor="#AAAAAA"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/etNotes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Receipt Preview -->
    <ImageView
        android:id="@+id/ivReceiptPreview"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="centerCrop"
        android:background="@drawable/bg_card"
        android:visibility="gone"
        android:contentDescription="Receipt preview"
        android:layout_marginStart="16dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/btnAttachPhoto"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Save Expense -->
    <Button
        android:id="@+id/btnSaveExpense"
        android:text="Add Expense"
        android:background="@drawable/bg_btn"
        android:textColor="#FFFFFF"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        app:layout_constraintTop_toBottomOf="@id/ivReceiptPreview"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
