<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:layout_marginHorizontal="12dp"
    android:background="@drawable/bg_card"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivCategoryIcon"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:src="@drawable/ic_category_placeholder"
        android:contentDescription="Category icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Groceries"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/ivCategoryIcon"
        app:layout_constraintTop_toTopOf="@id/ivCategoryIcon"
        app:layout_constraintEnd_toStartOf="@id/tvAmountSpent"/>

    <TextView
        android:id="@+id/tvAmountSpent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="R0.00"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <ProgressBar
        android:id="@+id/progressCategory"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="0dp"
        android:layout_height="8dp"
        android:progressDrawable="@drawable/progress_budget"
        android:max="100"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvCategoryName"
        app:layout_constraintStart_toStartOf="@id/tvCategoryName"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvProgressLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0%"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/progressCategory"
        app:layout_constraintStart_toStartOf="@id/progressCategory"/>

    <TextView
        android:id="@+id/tvBudgetLimit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="of R0"
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        app:layout_constraintTop_toTopOf="@id/tvProgressLabel"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDateRange"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvProgressLabel"
        app:layout_constraintStart_toStartOf="@id/tvProgressLabel"/>

</androidx.constraintlayout.widget.ConstraintLayout>