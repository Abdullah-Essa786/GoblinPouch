<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_gradient">

    <!-- Top nav — no elevation so it sits flush against the scroll content below -->
    <include layout="@layout/top_nav"/>

    <!-- Scroll area — layout_height="0dp" + layout_weight="1" fills space between navs -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- CARD: Monthly Budget -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <!-- Card label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Monthly Budget"
                    android:textColor="#AFCBFF"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Amount (left) + donut circle (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Spend amount and subtitle -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBudgetAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="R1,270 / R2,000"
                            android:textColor="#FFFFFF"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:letterSpacing="-0.02"/>

                        <TextView
                            android:id="@+id/tvBudgetPercent"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="63% Used"
                            android:textColor="#AFCBFF"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Donut circle — see res/drawable/bg_donut_circle.xml -->
                    <FrameLayout
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:layout_marginStart="14dp">

                        <View
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:background="@drawable/bg_donut_circle"/>

                        <!-- Percentage label centred inside the ring -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDonutPercent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="63%"
                                android:textColor="#FFFFFF"
                                android:textSize="16sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Used"
                                android:textColor="#AFCBFF"
                                android:textSize="9sp"/>

                        </LinearLayout>
                    </FrameLayout>

                </LinearLayout>

                <!-- Budget progress bar -->
                <ProgressBar
                    android:id="@+id/progressMonthly"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="7dp"
                    android:layout_marginTop="12dp"
                    android:progress="63"
                    android:progressTint="#4FC3F7"
                    android:progressBackgroundTint="#1AFFFFFF"
                    android:max="100"/>

            </LinearLayout>

            <!-- CARD: Category Budgets -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <!-- Card label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Category Budgets"
                    android:textColor="#AFCBFF"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Groceries row: icon | name | amount -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_grocery"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="Groceries"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Groceries"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="R1,320 / R1,500"
                        android:textColor="#AFCBFF"
                        android:textSize="13sp"/>

                </LinearLayout>

                <!-- Category progress bar -->
                <ProgressBar
                    android:id="@+id/progressGroceries"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="7dp"
                    android:progress="63"
                    android:progressTint="#4FC3F7"
                    android:progressBackgroundTint="#1AFFFFFF"
                    android:max="100"/>

                <!-- Right-aligned percentage label -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="63% Used"
                    android:textColor="#AFCBFF"
                    android:textSize="11sp"
                    android:gravity="end"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <!-- CARD: Budget Alerts -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/card_bg"
                android:layout_marginBottom="12dp">

                <!-- Card label — amber colour signals warning -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚠  Budget Alerts"
                    android:textColor="#FFAA00"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:letterSpacing="0.08"
                    android:layout_marginBottom="10dp"/>

                <!-- Alert row: icon (left) | body (right) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_grocery"
                        android:layout_marginEnd="8dp"
                        android:layout_marginTop="2dp"
                        android:contentDescription="Groceries"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Category name (left) | exceeded amount + warning icon (right) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Groceries"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="R700 / R450"
                                android:textColor="#FFFFFF"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:layout_marginEnd="6dp"/>

                            <!-- Warning icon -->
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="⚠"
                                android:textColor="#FFAA00"
                                android:textSize="16sp"/>

                        </LinearLayout>

                        <!-- Tri-colour bar — see res/drawable/bg_alert_progress.xml -->
                        <ProgressBar
                            android:id="@+id/progressGroceryAlert"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="7dp"
                            android:layout_marginTop="8dp"
                            android:progress="100"
                            android:progressDrawable="@drawable/bg_alert_progress"
                            android:max="100"/>

                        <!-- Footer: Remaining (left) | Goal (right) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Remaining"
                                android:textColor="#AFCBFF"
                                android:textSize="11sp"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Goal: R2,000"
                                android:textColor="#AFCBFF"
                                android:textSize="11sp"/>

                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Bottom nav bar -->
    <include layout="@layout/bottom_nav"/>

</LinearLayout>