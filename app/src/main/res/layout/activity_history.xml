<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:padding="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:id="@+id/tabMonth" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Month" android:textColor="#FFFFFF" android:gravity="center" android:background="@drawable/bg_btn"/>
        <TextView android:id="@+id/tabWeek" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Week" android:textColor="#AAAAAA" android:gravity="center"/>
        <TextView android:id="@+id/tabDay" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="Day" android:textColor="#AAAAAA" android:gravity="center"/>
    </LinearLayout>

    <include
        android:id="@+id/layoutSummaryCard"
        layout="@layout/summary_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <LinearLayout
        android:id="@+id/layoutDateSelection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutSummaryCard"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select Date Range"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_edit"
            android:padding="8dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistoryTransactions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/layoutDateSelection"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>