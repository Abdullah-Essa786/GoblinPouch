<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- Top Nav -->
    <include
        android:id="@+id/topNav"
        layout="@layout/top_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Tabs: Month | Week | Day -->
    <LinearLayout
        android:id="@+id/layoutTabs"
        android:layout_width="0dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:background="@drawable/bg_card"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        android:padding="2dp"
        app:layout_constraintTop_toBottomOf="@id/topNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tabMonth"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Month"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:background="@drawable/bg_btn"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tabWeek"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Week"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:textSize="14sp"/>

        <TextView
            android:id="@+id/tabDay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Day"
            android:textColor="#AAAAAA"
            android:gravity="center"
            android:textSize="14sp"/>
    </LinearLayout>

    <!-- Date Selection Bar -->
    <LinearLayout
        android:id="@+id/layoutDateSelection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@id/layoutTabs"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_calender"
            app:tint="#AAAAAA"/>

        <TextView
            android:id="@+id/tvDateRange"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01 Jan 2025 → 31 Mar 2025"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/bg_edit"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"
            android:layout_marginHorizontal="8dp"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_export"
            app:tint="#AAAAAA"/>
    </LinearLayout>

    <!-- Graph Container (Placeholder for Line Graph) -->
    <FrameLayout
        android:id="@+id/graphContainer"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        android:background="#0DFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/layoutDateSelection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Axis labels and grid placeholders could go here -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12.00"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:layout_gravity="top|start"
            android:layout_margin="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0.00"
            android:textColor="#55FFFFFF"
            android:textSize="10sp"
            android:layout_gravity="bottom|start"
            android:layout_margin="8dp"/>

    </FrameLayout>

    <!-- Categories List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvHistoryCategories"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/graphContainer"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Bottom Nav -->
    <include
        android:id="@+id/bottomNav"
        layout="@layout/bottom_nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>